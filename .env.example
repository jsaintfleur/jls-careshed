# ShelterShield environment variables
#
# The v1 NYC live demo requires NO keys — it runs on keyless NYC Open Data.
# The keys below are only needed to enable the additional (proposed) data domains
# whose ingestion scripts ship in scripts/ingest/.

# Census Data API key (for ACS affordability domain). Free: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# NYC Open Data (Socrata) app token — optional, raises rate limits for large pulls.
# Free: https://data.cityofnewyork.us/profile/app_tokens
SOCRATA_APP_TOKEN=
